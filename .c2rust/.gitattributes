# `diff=` entries configure language-aware diff drivers for `git diff` output (hunk headers).
# They do not affect pack delta compression.
*.rs  diff=rust
*.c   diff=c
*.h   diff=c

# `-delta` entries disable pack delta compression for binary/compiled artifacts,
# reducing meaningless pack bloat during git gc/repack.
*.o   -delta
*.a   -delta
*.so  -delta
